# Flask
SECRET_KEY=change-me-to-a-random-secret-key
FLASK_ENV=development
FLASK_DEBUG=1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///wc2026_fantasy.db

# Production (Render / Railway / Heroku): set FLASK_ENV=production
# TRUST_PROXY=1
# SESSION_COOKIE_SECURE=1

# football-data.org (free — register at https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN=your_football_data_token_here

# API-Football / api-sports.io (free tier 100 req/day — register at https://dashboard.api-football.com/register)
API_FOOTBALL_KEY=your_api_football_key_here

# No keys needed for worldcup26.ir or openfootball JSON

# Admin user emails (comma-separated) for sync endpoints
ADMIN_EMAILS=admin@example.com

# Cache backend: SimpleCache (default) or Redis
CACHE_TYPE=SimpleCache
# CACHE_REDIS_URL=redis://localhost:6379/0

# Mystery booster type (set when revealed before RO32)
MYSTERY_BOOSTER_TYPE=WILDCARD
